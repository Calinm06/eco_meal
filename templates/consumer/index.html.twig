{% extends 'base.html.twig' %}

{% block title %}Hello ConsumerController!{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 1500px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>

<div class="example-wrapper">
{#    <a href="{{ path('app_consumer_new') }}">Create a new consumer</a>#}
    <table class="table table-dark">
        <thead>
            <tr>
                <th>First Name</th>
                <th>Last Name</th>
                <th>Phone Number</th>
                <th></th>
            </tr>
        </thead>

        <tbody>
            {% for consumer in consumers %}
                <tr>
                    <td>{{ consumer.firstName }}</td>
                    <td>{{ consumer.lastName }}</td>
                    <td>{{ consumer.phoneNumber}}</td>
                    <td>
                        <a href="{{ path('app_consumer_delete',{id: consumer.id}) }}">
                            <img src="{{ asset('Icons/recycling-bin.png') }}" alt="delete" width="16" height="16">
                        </a>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
