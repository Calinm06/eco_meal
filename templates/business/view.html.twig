{% extends 'base.html.twig' %}

{% block title %}Hello BusinessController!{% endblock %}

{% block body %}
    <style>
        .example-wrapper { margin: 1em auto; max-width: 1500px; width: 95%; font: 18px/1.5 sans-serif; }
        .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
    </style>

    <div class="example-wrapper">
        <h1>This is the page for the {{ business.name }} business</h1>
        <p><b>Id:</b> {{ business.id }}</p>
        <p><b>Name</b> {{ business.name }}</p>
        <p><b>Street</b> {{ business.city }}</p>
        <p><b>Street</b>: {{ business.street }}</p>
        <p><b>House Number</b>: {{ business.houseNumber }}</p>
        <p><b>Phone Number: </b> {{ business.phoneNumber }}</p>
        <p><b>Business Type: </b>{{ business.businessType.name }}</p>

        <a class = "btn btn-primary" href={{ path('app_business') }}>Back</a>

       {% include 'package/table.html.twig' with {
           packages: business.packages
       } %}

        <a class= "btn btn-primary" href="{{ path('app_package_new', {id: business.id}) }}">Create new package</a>
    </div>

{% endblock %}
