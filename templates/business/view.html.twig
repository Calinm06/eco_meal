{% extends 'base.html.twig' %}

{% block title %}Hello BusinessController!{% endblock %}

{% block body %}
    {% include 'navbars/business.html.twig' %}
    <div class="index_wrapper">
        <h1 class="text-center"> Welcome {{ business.name }}!</h1>
        <p><b>City:</b> {{ business.city }}</p>
        <p><b>Street</b>: {{ business.street }}</p>
        <p><b>House Number</b>: {{ business.houseNumber }}</p>
        <p><b>Phone Number: </b> {{ business.phoneNumber }}</p>
        <p><b>Business Type: </b>{{ business.businessType.name }}</p>
    </div>
{% endblock %}
