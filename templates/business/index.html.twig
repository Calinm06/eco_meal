{% extends 'base.html.twig' %}

{% block title %}Hello BusinessController!{% endblock %}

{% block body %}

<div class="index_wrapper">
    <a class="btn btn-primary mb-3" href="{{ path('app_admin') }}">Back</a>
    <table class="table table-light">
        <thead>
        <tr class="table-primary">
            <th>Id</th>
            <th>Name</th>
            <th>City</th>
            <th>Street</th>
            <th>House Number</th>
            <th>Phone Number</th>
            <th>Business Type</th>
        </tr>
        </thead>
        <tbody>
        {% for business in businesses %}
            <tr>
                <td><a href={{ path('app_business_view',{
                        id:business.id
                    }) }}> {{ business.id }}</a></td>
                <td>{{ business.name }}</td>
                <td>{{ business.city }}</td>
                <td>{{ business.street}}</td>
                <td>{{ business.houseNumber}}</td>
                <td>{{ business.phoneNumber}}</td>
                <td>{{ business.businessType.name}}</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
