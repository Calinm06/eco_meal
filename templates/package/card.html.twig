{% if packages is empty %}
    <p>There are no packages</p>
{% else %}
    <div>
        <div class="row row-cols-3">
            {% for package in packages %}
                <div class="col">
                    <div class="bg-light border h-100 d-flex flex-column">

                        <div class="text-center p-1">
                            <h3 class="text-truncate mb-1">{{ package.business.name }}</h3>
                        </div>

                        <div class="text-center" style="height: 180px; overflow: hidden; flex-shrink: 0;">
                            {% if package.photo is not null %}
                                <img src="{{ asset(package.photo) }}" alt="Photo"
                                     style="width: 100%; height: 100%; object-fit: cover;">
                            {% else %}
                                <div class="bg-secondary bg-opacity-10 d-flex align-items-center justify-content-center h-100">
                                    <small class="text-muted">No image</small>
                                </div>
                            {% endif %}
                        </div>

                        <div class="p-2 d-flex flex-column flex-grow-1">
                            <div class="d-flex justify-content-between">
                                <p class="mb-0 text-truncate"><b>{{ package.name }}</b></p>
                                <p class="mb-0 flex-shrink-0 ms-2"><b>{{ package.price }}</b> RON</p>
                            </div>

                            <div class="d-flex mt-1">
                                <img class="mt-1" src="{{ asset('Icons/calendar.png') }}" alt="calendar" width="16" height="16">
                                <small class="ms-1">Made fresh today</small>
                            </div>

                            <div class="mt-1 flex-grow-1">
                                <small class="text-muted">{{ package.description }}</small>
                            </div>

                            {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_BUSINESS') %}
                                <div class="mt-auto pt-2">
                                    <a class="btn btn-danger" href="{{ path('app_package_delete',{'id':package.id}) }}">Delete</a>
                                    <a class="btn btn-primary" href="{{ path('app_package_edit',{'id':package.id}) }}">Edit</a>
                                </div>
                            {% endif %}

                            {% if app.user and is_granted('ROLE_CONSUMER') %}
                                <div class="mt-auto pt-2 text-center">
                                    <a class="btn btn-primary" href="{{ path('app_order_new',{
                                        package_id: package.id,
                                        consumer_id: app.user.consumer.id
                                    }) }}">Order</a>
                                </div>
                            {% endif %}
                        </div>

                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
{% endif %}
